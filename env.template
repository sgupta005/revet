# Database — use plain postgresql:// (code rewrites to +asyncpg for SQLAlchemy)
DATABASE_URL=postgresql://shivam:shivam2005@localhost:5432/revet

# Redis — Celery broker + result backend + token cache + dedup
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...
LLM_MODEL=openai:gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# GitHub App — register at https://github.com/settings/apps
GITHUB_APP_ID=
# Paste the PEM private key as a single string with literal \n between lines
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=

# GitHub OAuth (user-to-server) — Phase 5 frontend auth. Enable "Request user
# authorization (OAuth) during installation" on the App; the client id is public,
# the secret is backend-only and never exposed to the browser.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# CORS allow-list for the web frontend (credentialed); session lifetime in seconds.
FRONTEND_ORIGIN=http://localhost:3000
SESSION_TTL=604800

# LangSmith tracing — set LANGSMITH_TRACING=true to enable. These are bridged
# into os.environ at startup (app/observability.py) so LangChain/LangGraph
# auto-trace every graph run; no manual @traceable wrappers.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=revet
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Service
ENVIRONMENT=development
LOG_LEVEL=INFO
